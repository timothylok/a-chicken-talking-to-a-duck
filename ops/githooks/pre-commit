#!/bin/sh
# Regenerate the public home page whenever the command table changes, so
# gateway/public/index.html always matches COMMANDS in asr/router.py.
# Enabled via:  git config core.hooksPath ops/githooks
if git diff --cached --name-only | grep -q "^asr/router\.py$"; then
    python ops/generate_homepage.py || exit 1
    git add gateway/public/index.html
fi
