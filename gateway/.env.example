# Shared secret the iPhone client must send as "Authorization: Bearer <key>"
VOICE_GATEWAY_KEY=

# Cloudflare Tunnel endpoint of the local ASR service
ASR_URL=https://voice.fittertrack.com/inference

# Cloudflare Access service token (hardening checklist item 1).
# Optional until Access is configured on the tunnel hostname.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
